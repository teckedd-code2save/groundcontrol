# ─────────────────────────────────────────────────────────────────────────────
# GroundControl — environment variables
#
# Copy this file to `.env` and fill in real values:
#     cp .env.example .env
#
# All `.env*` files are gitignored. Never commit real secrets.
# Generate strong random values with:  openssl rand -hex 32
# ─────────────────────────────────────────────────────────────────────────────

# ── Required ─────────────────────────────────────────────────────────────────

# Signs the JWT auth cookie (`gc_token`). The app THROWS at runtime if this is
# unset — login and every authenticated API route will fail. Use a long random
# string and keep it stable (rotating it invalidates all existing sessions).
#   Generate:  openssl rand -hex 32
JWT_SECRET="change-me-to-a-long-random-string"

# Prisma SQLite connection string.
#   Local dev:  file:./dev.db   (relative to the prisma/ schema location)
# In the Docker image this is OVERRIDDEN to file:/app/prisma/prod.db on a named
# volume — you do not need to set it in production .env.
DATABASE_URL="file:./dev.db"


# ── Optional ─────────────────────────────────────────────────────────────────

# Powers the AI assistant (chat widget + dashboard insights) via the OpenAI API.
# If unset, the AI features return a 503 and prompt you to add a key in
# Settings → AI Configuration (stored in ai-config.json, also gitignored).
# Leave blank to disable AI entirely.
OPENAI_API_KEY=""

# Set automatically to `production` inside the Docker image. Controls the cookie
# `secure` flag (HTTPS-only cookies) and Prisma runtime behavior. Leave unset
# for local development.
# NODE_ENV="production"


# ── Docker Compose only ──────────────────────────────────────────────────────

# Host port that docker-compose binds to 127.0.0.1 (forwarded to the container's
# internal port 3000). Point your reverse proxy at this port. Default: 3003.
HOST_PORT=3003


# ── Reserved / forthcoming (introduced by sibling work, set when available) ──

# Application-wide secret used to encrypt sensitive values at rest (e.g. stored
# SSH private keys / VPS passwords in the SQLite DB). When this lands, set it to
# a long random value and DO NOT change it after first use, or stored secrets
# will become undecryptable.
#   Generate:  openssl rand -hex 32
# GROUNDCONTROL_SECRET=""

# Overrides the OpenAI chat model used by the AI assistant (default: gpt-4o-mini).
# Example values: gpt-4o-mini, gpt-4o, gpt-4.1-mini.
# AI_MODEL="gpt-4o-mini"
# AI_MODEL_OPENAI="gpt-4o-mini"

# Overrides the Anthropic chat model used by the AI assistant (default: claude-3-5-sonnet-latest).
# AI_MODEL_ANTHROPIC="claude-3-5-sonnet-latest"
