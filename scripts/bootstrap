#!/usr/bin/env bash
# scripts/bootstrap — one-command GroundControl installer
#
# Local (this machine is the VPS):
#   curl -fsSL <url> | bash
#
# Remote via SSH (default agent/keys):
#   curl -fsSL <url> | bash -s -- root@YOUR_IP
#
# Remote with a specific private key (like ssh -i):
#   curl -fsSL <url> | bash -s -- -i ~/.ssh/id_ed25519 root@YOUR_IP
#   curl -fsSL <url> | bash -s -- --identity /path/to/key -p 22 root@YOUR_IP
#
# Interactive (prompts for host / key if needed):
#   curl -fsSL <url> | bash -s -- --interactive
#   bash bootstrap --interactive
#
set -euo pipefail

RED='\033[0;31m'
GREEN='\033[0;32m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
YELLOW='\033[0;33m'
NC='\033[0m'

IDENTITY=""
IDENTITY_DISPLAY=""
PORT="22"           # SSH port
GC_HTTP_PORT=""     # Host port published for GC UI (never 80/443)
HOST=""
INTERACTIVE=0
SSH_EXTRA=()
TMP_KEY_FILE=""
# Candidate UI ports — high, uncommon, never edge 80/443
GC_PORT_CANDIDATES="3737 3847 3947 8765 9737 10037 18080 28080 38080"

usage() {
  cat <<'USAGE'
GroundControl Bootstrap

Usage:
  bash bootstrap                              Install on this machine
  bash bootstrap user@host                    Install on remote via SSH
  bash bootstrap -i KEY user@host             Use private key file (ssh -i)
  bash bootstrap -p PORT user@host            SSH port (default 22)
  bash bootstrap --interactive                Prompt for host / key path / paste

Examples:
  curl -fsSL …/bootstrap | bash -s -- -i ~/.ssh/id_ed25519 root@YOUR_IP
  curl -fsSL …/bootstrap | bash -s -- --interactive

Notes:
  • Use the PRIVATE key (id_ed25519), not the .pub public key
  • Paths: /Users/you/.ssh/key  or  ~/.ssh/key  or  .ssh/key
  • Interactive mode can paste a private key (PEM) when path resolution is hard
USAGE
}

cleanup() {
  if [ -n "${TMP_KEY_FILE:-}" ] && [ -f "$TMP_KEY_FILE" ]; then
    rm -f "$TMP_KEY_FILE"
  fi
}
trap cleanup EXIT INT TERM

# Read a line from the real terminal even when stdin is a pipe (curl | bash).
read_tty() {
  local prompt="$1"
  local var=""
  if [ -r /dev/tty ]; then
    # printf to tty; read from tty — avoid stdout mixing with command substitution
    printf "%s" "$prompt" > /dev/tty
    IFS= read -r var < /dev/tty || true
  elif [ -t 0 ]; then
    printf "%s" "$prompt" >&2
    IFS= read -r var || true
  fi
  printf "%s" "$var"
}

confirm_tty() {
  local prompt="$1"
  local ans
  ans=$(read_tty "$prompt")
  case "$ans" in
    y|Y|yes|YES) return 0 ;;
    *) return 1 ;;
  esac
}

trim() {
  local s="$1"
  # strip surrounding quotes and whitespace
  s="${s#"${s%%[![:space:]]*}"}"
  s="${s%"${s##*[![:space:]]}"}"
  s="${s#\"}"
  s="${s%\"}"
  s="${s#\'}"
  s="${s%\'}"
  printf "%s" "$s"
}

# Resolve a key path: ~/, $HOME, relative, ~/.ssh/basename, fuzzy match, warn on .pub
resolve_key_path() {
  local p raw base candidates c
  raw=$(trim "$1")
  p="$raw"

  if [ -z "$p" ]; then
    printf ""
    return 1
  fi

  # Expand leading ~  (avoid [[ == ~/* ]] which tilde-expands the pattern)
  case "$p" in
    "~") p="${HOME}" ;;
    "~/"*) p="${HOME}/${p#"~/"}" ;;
    "~"*) p="${HOME}/${p#"~"}" ;;
  esac

  # Strip accidental double-home: /Users/x/~/... or $HOME/~/...
  case "$p" in
    "${HOME}/~/"*) p="${HOME}/${p#"${HOME}/~/"}" ;;
    "${HOME}/~"*) p="${HOME}/${p#"${HOME}/~"}" ;;
  esac

  # Absolute path
  if [ "${p#/}" != "$p" ]; then
    :
  else
    # Relative: try cwd, then $HOME/, then $HOME/.ssh/
    if [ -f "$p" ]; then
      p="$(cd "$(dirname "$p")" && pwd)/$(basename "$p")"
    elif [ -f "${HOME}/$p" ]; then
      p="${HOME}/$p"
    elif [ -f "${HOME}/.ssh/$p" ]; then
      p="${HOME}/.ssh/$p"
    elif [ -f "${HOME}/.ssh/$(basename "$p")" ]; then
      p="${HOME}/.ssh/$(basename "$p")"
    else
      p="${HOME}/$p"
    fi
  fi

  # User gave a .pub — try the private key sibling
  if [ "${p%.pub}" != "$p" ]; then
    local priv="${p%.pub}"
    if [ -f "$priv" ]; then
      echo -e "${YELLOW}! You pointed at a public key (.pub). Using private key: ${priv}${NC}" >&2
      p="$priv"
    else
      echo -e "${YELLOW}! That looks like a public key (.pub). ssh -i needs the private key (no .pub).${NC}" >&2
      echo -e "  Tried sibling private key: ${priv} (not found)${NC}" >&2
    fi
  fi

  if [ -f "$p" ]; then
    printf "%s" "$p"
    return 0
  fi

  # Fuzzy: basename match in ~/.ssh (handles typos / missing trailing s)
  base=$(basename "$p")
  base="${base%.pub}"
  if [ -d "${HOME}/.ssh" ] && [ -n "$base" ]; then
    candidates=""
    # exact private
    [ -f "${HOME}/.ssh/${base}" ] && candidates="${HOME}/.ssh/${base}"
    # prefix matches (private files only)
    for c in "${HOME}/.ssh/"*; do
      [ -f "$c" ] || continue
      case "$c" in
        *.pub|*.old|*.bak|*known_hosts*|*config*|*authorized_keys*) continue ;;
      esac
      case "$(basename "$c")" in
        "${base}"*|*"${base}"*)
          if [ -z "$candidates" ]; then candidates="$c"
          else candidates="$candidates
$c"
          fi
          ;;
      esac
    done
    # Prefer single unique fuzzy hit
    if [ -n "$candidates" ] && [ "$(printf '%s\n' "$candidates" | grep -c .)" -eq 1 ]; then
      echo -e "${YELLOW}! Exact path missing; using closest private key: ${candidates}${NC}" >&2
      printf "%s" "$candidates"
      return 0
    fi
    if [ -n "$candidates" ]; then
      echo -e "${YELLOW}! Key not found at: ${p}${NC}" >&2
      echo -e "  Similar private keys in ~/.ssh:${NC}" >&2
      printf '%s\n' "$candidates" | while IFS= read -r c; do
        echo -e "    ${CYAN}$c${NC}" >&2
      done
    fi
  fi

  printf "%s" "$p"
  return 1
}

# Write pasted PEM key to a temp file (600)
write_pasted_key() {
  local content="$1"
  TMP_KEY_FILE=$(mktemp "${TMPDIR:-/tmp}/gc-ssh-key.XXXXXX")
  # Ensure trailing newline
  printf "%s\n" "$content" > "$TMP_KEY_FILE"
  chmod 600 "$TMP_KEY_FILE"
  IDENTITY="$TMP_KEY_FILE"
  IDENTITY_DISPLAY="(pasted private key)"
}

# Prompt user to paste a multi-line PEM private key via /dev/tty
prompt_paste_key() {
  local line body=""
  echo "" > /dev/tty 2>/dev/null || true
  echo -e "${BLUE}Paste your PRIVATE key (including -----BEGIN … END----- lines).${NC}" > /dev/tty 2>/dev/null || echo -e "${BLUE}Paste PRIVATE key, then a line with only: END${NC}"
  echo -e "When finished, type ${CYAN}END${NC} on its own line (or press Ctrl-D).${NC}" > /dev/tty 2>/dev/null || true
  echo "" > /dev/tty 2>/dev/null || true

  if [ -r /dev/tty ]; then
    while IFS= read -r line < /dev/tty || [ -n "$line" ]; do
      case "$line" in
        END|end|.) break ;;
      esac
      body="${body}${line}
"
      # Auto-stop after END PRIVATE KEY line
      case "$line" in
        *"END OPENSSH PRIVATE KEY"*|*"END RSA PRIVATE KEY"*|*"END EC PRIVATE KEY"*|*"END PRIVATE KEY"*)
          break
          ;;
      esac
    done
  else
    echo -e "${RED}✗ No TTY available to paste a key.${NC}" >&2
    return 1
  fi

  body=$(printf "%s" "$body" | sed -e 's/\r$//')
  if ! printf "%s" "$body" | grep -q "BEGIN.*PRIVATE KEY"; then
    echo -e "${RED}✗ Paste did not look like a private key (missing BEGIN PRIVATE KEY).${NC}" >&2
    echo -e "  Do not paste the .pub file — use the private key without .pub${NC}" >&2
    return 1
  fi
  write_pasted_key "$body"
  echo -e "${GREEN}✓ Private key received (temporary file, deleted on exit)${NC}"
  return 0
}

# Apply IDENTITY to SSH_EXTRA (path or already set temp file)
build_ssh_base() {
  SSH_EXTRA=(-o ConnectTimeout=10 -o StrictHostKeyChecking=accept-new -o ServerAliveInterval=15 -o BatchMode=yes)
  if [ -n "$PORT" ] && [ "$PORT" != "22" ]; then
    SSH_EXTRA+=(-p "$PORT")
  fi
  if [ -n "$IDENTITY" ]; then
    # If IDENTITY still looks like a path (not our temp), resolve it
    if [ -z "$TMP_KEY_FILE" ] || [ "$IDENTITY" != "$TMP_KEY_FILE" ]; then
      local resolved
      if resolved=$(resolve_key_path "$IDENTITY"); then
        IDENTITY="$resolved"
        IDENTITY_DISPLAY="$resolved"
      else
        echo -e "${RED}✗ SSH key not found: ${resolved:-$IDENTITY}${NC}" >&2
        echo "" >&2
        echo "  Tips:" >&2
        echo "  • Use the PRIVATE key path, e.g. ~/.ssh/id_ed25519 (not .pub)" >&2
        echo "  • Absolute: /Users/you/.ssh/id_ed25519" >&2
        echo "  • Or re-run with --interactive and choose paste" >&2
        exit 1
      fi
    fi
    chmod 600 "$IDENTITY" 2>/dev/null || true
    SSH_EXTRA+=(-i "$IDENTITY" -o IdentitiesOnly=yes)
  fi
}

ssh_cmd() {
  # CRITICAL: never let ssh steal stdin. When the script is run as
  #   curl … | bash -s -- …
  # stdin is the script body. OpenSSH reads stdin by default and would
  # consume the rest of the bootstrap, so bash hits EOF right after the
  # first successful "echo ok" and silently exits without installing.
  ssh -n "${SSH_EXTRA[@]}" "$@" </dev/null
}

# Pick a free host TCP port that is not 80/443 and not already listening.
# Works on Linux (ss/netstat). Falls back to high ephemeral range.
find_free_http_port_local() {
  local p used
  used=$( (ss -lntH 2>/dev/null || netstat -lnt 2>/dev/null || true) | tr -s ' ' | sed -n 's/.*:\([0-9][0-9]*\) .*/\1/p' | sort -un )
  for p in $GC_PORT_CANDIDATES; do
    if ! printf '%s\n' "$used" | grep -qx "$p"; then
      printf '%s' "$p"
      return 0
    fi
  done
  for p in $(seq 20000 20100); do
    if ! printf '%s\n' "$used" | grep -qx "$p"; then
      printf '%s' "$p"
      return 0
    fi
  done
  printf '28173'
}

find_free_http_port_remote() {
  local p
  p=$(remote "used=\$( (ss -lntH 2>/dev/null || netstat -lnt 2>/dev/null || true) | tr -s ' ' | sed -n 's/.*:\\([0-9][0-9]*\\) .*/\\1/p' | sort -un );
for p in ${GC_PORT_CANDIDATES}; do
  echo \"\$used\" | grep -qx \"\$p\" && continue
  echo \"\$p\"; exit 0
done
for p in \$(seq 20000 20100); do
  echo \"\$used\" | grep -qx \"\$p\" && continue
  echo \"\$p\"; exit 0
done
echo 28173" 2>/dev/null | tr -d '\r' | tail -1)
  p=$(trim "${p:-}")
  if [ -z "$p" ] || ! printf '%s' "$p" | grep -Eq '^[0-9]+$'; then
    p="28173"
  fi
  # Never allow edge ports even if probe misbehaves
  if [ "$p" = "80" ] || [ "$p" = "443" ] || [ "$p" = "22" ]; then
    p="28173"
  fi
  printf '%s' "$p"
}

# Fresh bootstrap compose — NEVER uses /opt/groundcontrol (production path).
# Isolated project + container names so we cannot orphan/remove groundcontrol-web.
write_bootstrap_compose_yaml() {
  local http_port="$1"
  local jwt_secret="$2"
  cat <<EOF
# Generated by GroundControl bootstrap (side-by-side install).
# Project: gcbootstrap — does NOT manage production groundcontrol-web.
# Does NOT bind 80/443.
name: gcbootstrap

services:
  app:
    image: ghcr.io/teckedd-code2save/groundcontrol:latest
    container_name: groundcontrol-bootstrap
    restart: unless-stopped
    ports:
      - "${http_port}:3000"
    environment:
      - NODE_ENV=production
      - PORT=3000
      - HOSTNAME=0.0.0.0
      - DATABASE_URL=file:/app/prisma/prod.db
      - JWT_SECRET=${jwt_secret}
    volumes:
      - /var/run/docker.sock:/var/run/docker.sock
      - gcbootstrap-db:/app/prisma
      - /opt:/opt:ro
      - /etc:/etc:ro
    healthcheck:
      test: ["CMD", "wget", "--spider", "-q", "http://127.0.0.1:3000/"]
      interval: 30s
      timeout: 10s
      retries: 5
      start_period: 25s

volumes:
  gcbootstrap-db:
EOF
}

# Production layout used by CI/CD (Caddy typically proxies 127.0.0.1:3003).
write_production_compose_yaml() {
  cat <<'EOF'
# GroundControl production compose (restored by bootstrap if clobbered)
version: "3.8"

services:
  web:
    image: ghcr.io/teckedd-code2save/groundcontrol:latest
    container_name: groundcontrol-web
    restart: unless-stopped
    ports:
      - "127.0.0.1:3003:3000"
    env_file:
      - .env
    environment:
      - NODE_ENV=production
      - DATABASE_URL=file:/app/prisma/prod.db
    volumes:
      - groundcontrol-db:/app/prisma
      - /var/run/docker.sock:/var/run/docker.sock
      - /opt:/opt
      - /etc:/etc
      - /var/www:/var/www
      - /root/.ssh:/root/.ssh:ro
    healthcheck:
      test: ["CMD", "wget", "--spider", "-q", "http://127.0.0.1:3000/"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 15s

volumes:
  groundcontrol-db:
EOF
}

# Interactive helper: path or paste
prompt_identity() {
  local choice path
  echo ""
  echo "  How do you want to provide the SSH private key?"
  echo "    1) Path to key file  (e.g. ~/.ssh/id_ed25519)"
  echo "    2) Paste private key now"
  echo "    3) Use ssh-agent / default keys only"
  choice=$(read_tty "Choice [1/2/3]: ")
  case "$choice" in
    2|p|P|paste|Paste)
      prompt_paste_key || return 1
      ;;
    3|a|A|agent|"")
      IDENTITY=""
      IDENTITY_DISPLAY="(ssh-agent / defaults)"
      ;;
    1|path|Path|*)
      path=$(read_tty "Path to private key (e.g. ~/.ssh/id_ed25519): ")
      path=$(trim "$path")
      if [ -z "$path" ]; then
        IDENTITY=""
        IDENTITY_DISPLAY="(ssh-agent / defaults)"
      else
        resolved=""
        if resolved=$(resolve_key_path "$path"); then
          IDENTITY="$resolved"
          IDENTITY_DISPLAY="$resolved"
          echo -e "${GREEN}✓ Using key file: ${IDENTITY}${NC}"
        else
          echo -e "${YELLOW}! Path not found: ${resolved:-$path}${NC}"
          if confirm_tty "Paste private key instead? [y/N] "; then
            prompt_paste_key || return 1
          else
            return 1
          fi
        fi
      fi
      ;;
  esac
  return 0
}

# Parse args
while [ $# -gt 0 ]; do
  case "$1" in
    -h|--help)
      usage
      exit 0
      ;;
    -i|--identity|--key)
      shift
      IDENTITY="${1:-}"
      if [ -z "$IDENTITY" ]; then
        echo -e "${RED}✗ -i requires a path to a private key${NC}" >&2
        exit 1
      fi
      shift
      ;;
    -p|--port)
      shift
      PORT="${1:-22}"
      shift
      ;;
    -y|--yes)
      # reserved for non-interactive future use
      shift
      ;;
    --interactive|-I)
      INTERACTIVE=1
      shift
      ;;
    --)
      shift
      break
      ;;
    -*)
      echo -e "${RED}✗ Unknown option: $1${NC}" >&2
      usage
      exit 1
      ;;
    *)
      if [ -z "$HOST" ]; then
        HOST="$1"
      else
        echo -e "${YELLOW}! Ignoring extra argument: $1${NC}" >&2
      fi
      shift
      ;;
  esac
done

# Remaining positional after --
while [ $# -gt 0 ]; do
  if [ -z "$HOST" ]; then
    HOST="$1"
  fi
  shift
done

echo ""
echo -e "${CYAN}◉ GroundControl Bootstrap${NC}"
echo ""

# Interactive: gather host / key if missing
if [ "$INTERACTIVE" -eq 1 ] || { [ -z "$HOST" ] && [ -r /dev/tty ] && confirm_tty "Install on a remote VPS via SSH? [y/N] "; }; then
  if [ -z "$HOST" ]; then
    HOST=$(read_tty "SSH target (user@host): ")
    HOST=$(trim "$HOST")
  fi
  if [ -z "$HOST" ]; then
    echo -e "${BLUE}→ No host given — installing locally on this machine.${NC}"
  else
    PORT_IN=$(read_tty "SSH port [${PORT}]: ")
    PORT_IN=$(trim "$PORT_IN")
    if [ -n "$PORT_IN" ]; then
      PORT="$PORT_IN"
    fi
    if [ -z "$IDENTITY" ]; then
      prompt_identity || exit 1
    fi
  fi
  INTERACTIVE=1
fi

if [ -z "$HOST" ]; then
  # ── Local install ─────────────────────────────────────
  echo -e "${BLUE}→ Installing locally on this machine...${NC}"
  echo ""

  OS_ID=$(grep ^ID= /etc/os-release 2>/dev/null | cut -d= -f2 | tr -d '"' || echo 'unknown')
  echo -e "${GREEN}✓ OS: ${OS_ID}${NC}"

  if docker --version >/dev/null 2>&1; then
    echo -e "${GREEN}✓ Docker already installed${NC}"
  else
    echo -e "${BLUE}→ Installing Docker...${NC}"
    curl -fsSL https://get.docker.com | sh || {
      echo -e "${RED}✗ Docker install failed${NC}"
      exit 1
    }
    echo -e "${GREEN}✓ Docker installed${NC}"
  fi

  echo -e "${BLUE}→ Deploying GroundControl...${NC}"
  mkdir -p /opt/groundcontrol
  # Never clobber production /opt/groundcontrol
  if [ -f /opt/groundcontrol/docker-compose.yml ] && grep -q 'groundcontrol-web\|container_name: groundcontrol-web' /opt/groundcontrol/docker-compose.yml 2>/dev/null; then
    echo -e "${YELLOW}! Production GroundControl already present at /opt/groundcontrol — leaving it alone.${NC}"
    echo -e "  Manage it with: cd /opt/groundcontrol && docker compose up -d"
    exit 0
  fi

  echo -e "${BLUE}→ Choosing a free UI port (will not use 80/443)...${NC}"
  GC_HTTP_PORT=$(find_free_http_port_local)
  JWT_SECRET=$(openssl rand -hex 32 2>/dev/null || head -c 32 /dev/urandom | od -An -tx1 | tr -d ' \n')
  echo -e "${GREEN}✓ Publishing host port ${GC_HTTP_PORT} → container 3000${NC}"

  mkdir -p /opt/groundcontrol-bootstrap
  write_bootstrap_compose_yaml "$GC_HTTP_PORT" "$JWT_SECRET" > /opt/groundcontrol-bootstrap/docker-compose.yml

  cd /opt/groundcontrol-bootstrap
  if docker compose version >/dev/null 2>&1; then
    docker compose -p gcbootstrap up -d --pull always
  else
    docker-compose -p gcbootstrap up -d
  fi

  echo ""
  echo -e "${GREEN}╔══════════════════════════════════════════╗${NC}"
  echo -e "${GREEN}║   GroundControl is running!             ║${NC}"
  echo -e "${GREEN}╚══════════════════════════════════════════╝${NC}"
  echo ""
  echo -e "  Open:  ${CYAN}http://localhost:${GC_HTTP_PORT}${NC}"
  echo -e "  Setup: ${CYAN}http://localhost:${GC_HTTP_PORT}/onboarding${NC}"
  echo ""
  echo -e "  ${YELLOW}Safe install notes:${NC}"
  echo -e "  • Install dir: ${CYAN}/opt/groundcontrol-bootstrap${NC} (not production /opt/groundcontrol)"
  echo -e "  • Did not bind ports 80 or 443"
  echo -e "  • Container: ${CYAN}groundcontrol-bootstrap${NC} only"
  echo ""
  echo -e "  ${GREEN}Done. Your VPS has an AI co-pilot.${NC}"
  echo ""
  exit 0
fi

# ── Remote install via SSH ──────────────────────────────
# Note: with set -e, any failing SSH probe after "connection OK" used to abort
# the whole script. Use remote() helpers that never kill the install mid-flight.

remote() {
  # Run remote command; return ssh exit code but never trip set -e by itself
  ssh_cmd "$HOST" "$@"
  return $?
}

remote_ok() {
  remote "$@" >/dev/null 2>&1
}

echo -e "  Target: ${BLUE}${HOST}${NC}"
if [ -n "${IDENTITY_DISPLAY:-$IDENTITY}" ]; then
  echo -e "  Key:    ${BLUE}${IDENTITY_DISPLAY:-$IDENTITY}${NC}"
fi
if [ "$PORT" != "22" ]; then
  echo -e "  Port:   ${BLUE}${PORT}${NC}"
fi
echo ""

build_ssh_base

echo -e "${BLUE}→ Testing SSH connection...${NC}"
if ! remote_ok "echo ok"; then
  echo -e "${YELLOW}! SSH with current credentials failed.${NC}"

  if { [ -r /dev/tty ] || [ -t 0 ]; }; then
    echo ""
    echo "  If you normally run:"
    echo -e "    ${CYAN}ssh -i ~/.ssh/your_private_key ${HOST}${NC}"
    echo "  use that same private key path (not the .pub), or paste the key."
    echo ""
    # Keep existing temp key if paste already worked earlier in this run
    if [ -z "$IDENTITY" ] || [ ! -f "$IDENTITY" ]; then
      IDENTITY=""
      TMP_KEY_FILE=""
      prompt_identity || exit 1
    fi
    build_ssh_base
    if remote_ok "echo ok"; then
      echo -e "${GREEN}✓ SSH connection working${NC}"
    else
      echo -e "${RED}✗ Still cannot SSH to ${HOST}${NC}"
      echo ""
      echo "  Tried: ssh ${SSH_EXTRA[*]} ${HOST}"
      echo "  Check:"
      echo "  1. Host is reachable"
      echo "  2. You used the PRIVATE key (file without .pub)"
      echo "  3. Manual test: ssh -i ${IDENTITY:-~/.ssh/id_ed25519} -p ${PORT} ${HOST}"
      echo "  4. Install public key on server: ssh-copy-id -i KEY.pub ${HOST}"
      exit 1
    fi
  else
    echo -e "${RED}✗ Cannot SSH to ${HOST}${NC}"
    echo ""
    echo "  Pass a private key explicitly:"
    echo -e "    ${CYAN}curl -fsSL https://raw.githubusercontent.com/teckedd-code2save/groundcontrol/main/scripts/bootstrap | bash -s -- -i ~/.ssh/id_ed25519 ${HOST}${NC}"
    echo "  Or: bash -s -- --interactive   (path or paste)"
    exit 1
  fi
else
  echo -e "${GREEN}✓ SSH connection working${NC}"
fi

# Keep going even if probes fail (set -e safe)
echo -e "${BLUE}→ Detecting remote OS...${NC}"
OS_ID=$(remote "cat /etc/os-release 2>/dev/null | grep ^ID= | head -1 | cut -d= -f2 | tr -d '\"'" 2>/dev/null || true)
OS_ID=$(trim "${OS_ID:-}")
if [ -z "$OS_ID" ]; then
  OS_ID="unknown"
fi
echo -e "${GREEN}✓ Remote OS: ${OS_ID}${NC}"

echo -e "${BLUE}→ Checking Docker...${NC}"
if remote_ok "command -v docker >/dev/null 2>&1 && docker --version >/dev/null 2>&1"; then
  echo -e "${GREEN}✓ Docker already installed (left as-is — not reinstalling)${NC}"
else
  echo -e "${BLUE}→ Installing Docker on ${HOST} (only if missing)...${NC}"
  if ! remote "curl -fsSL https://get.docker.com | sh"; then
    echo -e "${RED}✗ Docker install failed${NC}"
    exit 1
  fi
  # Start docker only if we just installed it
  remote "command -v systemctl >/dev/null 2>&1 && systemctl enable --now docker 2>/dev/null || service docker start 2>/dev/null || true" || true
  echo -e "${GREEN}✓ Docker installed${NC}"
fi

# ── Protect / recover production at /opt/groundcontrol ──
# Previous bootstrap versions wrote into /opt/groundcontrol and removed
# groundcontrol-web via --remove-orphans. If production markers exist, restore.
echo -e "${BLUE}→ Checking for existing production GroundControl...${NC}"
HAS_PROD_ENV=0
HAS_PROD_VOL=0
HAS_BOOTSTRAP_CT=0
remote_ok "test -f /opt/groundcontrol/.env" && HAS_PROD_ENV=1
remote_ok "docker volume ls -q 2>/dev/null | grep -qx groundcontrol_groundcontrol-db || docker volume ls -q 2>/dev/null | grep -q groundcontrol-db" && HAS_PROD_VOL=1
remote_ok "docker ps -a --format '{{.Names}}' 2>/dev/null | grep -qx groundcontrol" && HAS_BOOTSTRAP_CT=1

if [ "$HAS_PROD_ENV" -eq 1 ] || [ "$HAS_PROD_VOL" -eq 1 ] || remote_ok "test -d /opt/groundcontrol"; then
  echo -e "${YELLOW}! Existing /opt/groundcontrol detected — restoring production layout (Caddy-friendly).${NC}"
  echo -e "  This undoes bootstrap clobber of groundcontrol-web and leaves edge ports alone."

  # Stop the accidental bootstrap container name (not groundcontrol-web)
  remote "docker rm -f groundcontrol groundcontrol-bootstrap 2>/dev/null || true" || true
  # Tear down only the mistaken bootstrap project if present
  remote "docker compose -p groundcontrol -f /opt/groundcontrol/docker-compose.yml down 2>/dev/null || true" || true
  remote "docker compose -p gcbootstrap down 2>/dev/null || true" || true

  # Ensure .env has JWT_SECRET
  remote "mkdir -p /opt/groundcontrol
cd /opt/groundcontrol
if [ ! -f .env ]; then
  touch .env
fi
if ! grep -q '^JWT_SECRET=' .env 2>/dev/null; then
  echo \"JWT_SECRET=\$(openssl rand -hex 32 2>/dev/null || head -c 32 /dev/urandom | od -An -tx1 | tr -d ' \\n')\" >> .env
  echo 'JWT_SECRET added to .env'
fi
# Keep HOST_PORT for Caddy → 127.0.0.1:3003
if ! grep -q '^HOST_PORT=' .env 2>/dev/null; then
  echo 'HOST_PORT=3003' >> .env
fi" || true

  PROD_B64=$(write_production_compose_yaml | base64 | tr -d '\n')
  if ! remote "echo '${PROD_B64}' | base64 -d > /opt/groundcontrol/docker-compose.yml"; then
    remote "echo '${PROD_B64}' | openssl base64 -d -A > /opt/groundcontrol/docker-compose.yml" || {
      echo -e "${RED}✗ Could not write production docker-compose.yml${NC}"
      exit 1
    }
  fi

  echo -e "${BLUE}→ Starting production container groundcontrol-web on 127.0.0.1:3003...${NC}"
  if ! remote "cd /opt/groundcontrol && (docker compose up -d --pull always || docker-compose up -d)"; then
    echo -e "${RED}✗ Failed to start production GroundControl${NC}"
    remote "cd /opt/groundcontrol && docker compose logs --tail=50" || true
    exit 1
  fi

  if remote_ok "sleep 3; wget -qO- --timeout=5 http://127.0.0.1:3003/ >/dev/null 2>&1 || curl -sf --max-time 5 http://127.0.0.1:3003/ >/dev/null"; then
    echo -e "${GREEN}✓ Production GC responding on 127.0.0.1:3003 (for Caddy/Nginx)${NC}"
  else
    echo -e "${YELLOW}! Started groundcontrol-web but HTTP check on :3003 failed — check logs${NC}"
    remote "cd /opt/groundcontrol && docker compose ps && docker compose logs --tail=40" || true
  fi

  HOST_IP=$(echo "$HOST" | sed 's/.*@//')
  echo ""
  echo -e "${GREEN}╔══════════════════════════════════════════╗${NC}"
  echo -e "${GREEN}║   Production GroundControl restored     ║${NC}"
  echo -e "${GREEN}╚══════════════════════════════════════════╝${NC}"
  echo ""
  echo -e "  Domain:   your Caddy/Nginx site → ${CYAN}127.0.0.1:3003${NC}"
  echo -e "  Direct:   ${CYAN}http://${HOST_IP}:3003${NC} (loopback only — use reverse proxy)"
  echo -e "  Path:     ${CYAN}/opt/groundcontrol${NC}"
  echo -e "  Container:${CYAN}groundcontrol-web${NC}"
  echo ""
  echo -e "  Bootstrap will never install into /opt/groundcontrol again."
  echo -e "  Fresh side-by-side installs use ${CYAN}/opt/groundcontrol-bootstrap${NC}."
  echo ""
  exit 0
fi

# ── Fresh install: side-by-side dir, never production path ──
echo -e "${BLUE}→ Fresh install into /opt/groundcontrol-bootstrap (not production path)...${NC}"
echo -e "${BLUE}→ Choosing a free UI port (never 80/443)...${NC}"
GC_HTTP_PORT=$(find_free_http_port_remote)
JWT_SECRET=$(openssl rand -hex 32 2>/dev/null || head -c 32 /dev/urandom | od -An -tx1 | tr -d ' \n')
echo -e "${GREEN}✓ Will publish host port ${GC_HTTP_PORT} → container 3000${NC}"

if ! remote "mkdir -p /opt/groundcontrol-bootstrap"; then
  echo -e "${RED}✗ Could not create /opt/groundcontrol-bootstrap${NC}"
  exit 1
fi

COMPOSE_B64=$(write_bootstrap_compose_yaml "$GC_HTTP_PORT" "$JWT_SECRET" | base64 | tr -d '\n')
if ! remote "echo '${COMPOSE_B64}' | base64 -d > /opt/groundcontrol-bootstrap/docker-compose.yml"; then
  if ! remote "echo '${COMPOSE_B64}' | openssl base64 -d -A > /opt/groundcontrol-bootstrap/docker-compose.yml 2>/dev/null"; then
    echo -e "${RED}✗ Could not write bootstrap docker-compose.yml${NC}"
    exit 1
  fi
fi

echo -e "${BLUE}→ Starting container groundcontrol-bootstrap (project gcbootstrap)...${NC}"
if ! remote "cd /opt/groundcontrol-bootstrap && (docker compose -p gcbootstrap up -d --pull always || docker-compose -p gcbootstrap up -d)"; then
  echo -e "${RED}✗ docker compose up failed${NC}"
  remote "cd /opt/groundcontrol-bootstrap && docker compose -p gcbootstrap logs --tail=40" || true
  exit 1
fi

echo -e "${BLUE}→ Verifying app on :${GC_HTTP_PORT}...${NC}"
if remote_ok "sleep 3; wget -qO- --timeout=5 http://127.0.0.1:${GC_HTTP_PORT}/ >/dev/null 2>&1 || curl -sf --max-time 5 http://127.0.0.1:${GC_HTTP_PORT}/ >/dev/null"; then
  echo -e "${GREEN}✓ App is responding on port ${GC_HTTP_PORT}${NC}"
else
  echo -e "${YELLOW}! Local HTTP check failed — logs:${NC}"
  remote "cd /opt/groundcontrol-bootstrap && docker compose -p gcbootstrap ps && docker compose -p gcbootstrap logs --tail=40" || true
fi

HOST_IP=$(echo "$HOST" | sed 's/.*@//')
echo ""
echo -e "${GREEN}╔══════════════════════════════════════════╗${NC}"
echo -e "${GREEN}║   GroundControl is running!             ║${NC}"
echo -e "${GREEN}╚══════════════════════════════════════════╝${NC}"
echo ""
echo -e "  Open:     ${CYAN}http://${HOST_IP}:${GC_HTTP_PORT}${NC}"
echo -e "  Setup:    ${CYAN}http://${HOST_IP}:${GC_HTTP_PORT}/onboarding${NC}"
echo ""
echo -e "  ${YELLOW}Isolation guarantees:${NC}"
echo -e "  • Install dir: ${CYAN}/opt/groundcontrol-bootstrap${NC}"
echo -e "  • Production path ${CYAN}/opt/groundcontrol${NC} was not modified"
echo -e "  • Ports 80 / 443 / 22 were not claimed"
echo -e "  • Container name: ${CYAN}groundcontrol-bootstrap${NC} only"
echo -e "  • Firewall was not changed"
echo ""
echo -e "  ${GREEN}Done. Your VPS has an AI co-pilot.${NC}"
echo ""
exit 0
