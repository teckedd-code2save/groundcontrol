generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                 Int      @id @default(autoincrement())
  username           String   @unique
  password           String   // bcrypt hash
  role               String   @default("admin")
  forcePasswordChange Boolean @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  auditLogs AuditLog[]
}

model AuditLog {
  id          Int      @id @default(autoincrement())
  userId      Int
  action      String   // login | logout | password_change | login_failed
  ip          String   @default("")
  userAgent   String   @default("")
  metadata    String   @default("") // JSON string for extra context
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([action, createdAt])
}

model VpsConfig {
  id        Int      @id @default(autoincrement())
  name      String   @default("primary")
  host      String
  port      Int      @default(22)
  username  String   @default("root")
  privateKey String? // AES-256-GCM encrypted at rest (see src/lib/crypto.ts)
  authType  String   @default("key") // key | password
  password  String? // AES-256-GCM encrypted at rest (see src/lib/crypto.ts)
  isLocal   Boolean  @default(false) // true = running on VPS, exec directly
  isActive  Boolean  @default(false) // exactly one active VPS; all pages target it
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  systemConfig SystemConfig?
  deploymentTargets DeploymentTarget[]
}

model Project {
  id          Int      @id @default(autoincrement())
  slug        String   @unique
  name        String
  domain      String?
  path        String   // /opt/slug or /var/www/slug
  repoUrl     String?
  buildCommand String?
  outputDir   String?
  dockerfile  String?
  envVars     String?  // JSON object of default env vars
  caddyFile   String?
  dockerCompose String?
  category    String   @default("app") // app | static | docker
  status      String   @default("unknown")
  lastDeploy  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  deployments Deployment[]
}

model DeploymentTarget {
  id           Int      @id @default(autoincrement())
  name         String
  type         String   // docker-compose | static | nixpacks | custom
  vpsConfigId  Int?
  cloudProviderAccountId Int? // GCP/AWS/Azure account for cloud targets
  configJson   String   @default("") // target-specific configuration
  isActive     Boolean  @default(false)
  dnsRecordId  String?  // Cloudflare DNS record created by this target
  dnsRecordName String? // Name of the Cloudflare DNS record created by this target
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  vps VpsConfig? @relation(fields: [vpsConfigId], references: [id], onDelete: SetNull)
  cloudAccount CloudProviderAccount? @relation(fields: [cloudProviderAccountId], references: [id], onDelete: SetNull)
  deployments Deployment[]

  @@index([type, isActive])
}

model Job {
  id          Int      @id @default(autoincrement())
  type        String   // deploy | build | rollback | terraform_apply
  status      String   @default("pending") // pending | running | success | failed | cancelled
  payload     String   // JSON
  output      String   @default("")
  result      String?  // JSON
  error       String?
  startedAt   DateTime?
  finishedAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  deployments Deployment[]

  @@index([status, createdAt])
  @@index([type, status])
}

model Deployment {
  id                 Int      @id @default(autoincrement())
  projectId          Int
  targetId           Int
  jobId              Int?     // Background job tracking real-time logs
  status             String   @default("pending") // pending | building | deploying | success | failed | rolled_back
  branch             String   @default("main")
  commitSha          String?
  imageTag           String?
  publicUrl          String?
  previewUrl         String?
  previewProcessInfo String?  // PID/log path for ephemeral quick tunnels
  idempotencyKey     String?
  output             String?
  error              String?
  durationMs         Int?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  target  DeploymentTarget @relation(fields: [targetId], references: [id], onDelete: Cascade)
  job     Job? @relation(fields: [jobId], references: [id], onDelete: SetNull)

  @@index([projectId, createdAt])
  @@index([targetId, createdAt])
  @@index([idempotencyKey])
}

model DeploymentLog {
  id        Int      @id @default(autoincrement())
  projectSlug String
  status    String   @default("running") // running | success | failed | rolled_back
  commitSha String?
  branch    String   @default("main")
  output    String?
  error     String?
  durationMs Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Alert {
  id        Int      @id @default(autoincrement())
  title     String
  message   String
  severity  String   @default("info") // info | warning | error | critical
  source    String   @default("system")
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model MetricSnapshot {
  id        Int      @id @default(autoincrement())
  cpuLoad1  Float
  cpuLoad5  Float
  cpuLoad15 Float
  memUsed   Float
  memTotal  Float
  memPercent Float
  diskUsed  Float
  diskTotal Float
  diskPercent Float
  containerCount Int
  runningContainers Int
  unhealthyContainers Int
  createdAt DateTime @default(now())
}

model SiteContainerMap {
  id            Int      @id @default(autoincrement())
  siteDomain    String
  containerName String
  createdAt     DateTime @default(now())

  @@unique([siteDomain, containerName])
}

model SystemConfig {
  id             Int    @id @default(autoincrement())
  vpsConfigId    Int?   @unique // links this filesystem layout to a specific VPS; null = global/legacy default
  projectRoot    String @default("/opt")
  caddySitesDir  String @default("/etc/caddy/sites")
  caddyFile      String @default("/etc/caddy/Caddyfile")
  nginxSitesDir  String @default("/etc/nginx/sites-available")
  nginxLogPath   String @default("/var/log/nginx/error.log")
  staticRoot     String @default("/var/www")
  sshDefaultCwd  String @default("/root")
  certDomain     String @default("")
  composeCommand String? // override docker compose command: "docker compose", "docker-compose", "podman-compose"
  updatedAt      DateTime @updatedAt

  vps VpsConfig? @relation(fields: [vpsConfigId], references: [id], onDelete: Cascade)
}

model CloudProviderAccount {
  id          Int      @id @default(autoincrement())
  name        String
  provider    String   // gcp | aws | azure
  credentials String   // encrypted JSON
  isActive    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  deploymentTargets DeploymentTarget[]

  @@index([provider, isActive])
}

model TerraformStack {
  id           Int      @id @default(autoincrement())
  name         String
  provider     String   // hetzner | aws | gcp | azure
  workspace    String   @default("default")
  hcl          String   // generated Terraform configuration
  varsJson     String   @default("") // encrypted terraform.tfvars
  stateBackend String   @default("local") // local | s3 | gcs
  statePath    String?  // where state is stored
  lastPlan     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([provider, workspace])
}

model CloudflareAccount {
  id          Int      @id @default(autoincrement())
  name        String   @default("Cloudflare")
  apiToken    String   // encrypted at rest
  accountId   String?
  email       String?
  isActive    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tunnels CloudflareTunnel[]
}

model CloudflareTunnel {
  id          Int      @id @default(autoincrement())
  tunnelId    String   @unique // Cloudflare tunnel ID (UUID)
  name        String
  tunnelSecret String? // base64 secret for cloudflared
  connectorId String?  // optional running container id
  status      String   @default("inactive") // active | inactive | error
  domains     String   @default("") // comma-separated list
  configJson  String   @default("") // ingress JSON snapshot
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  account CloudflareAccount @relation(fields: [cloudflareAccountId], references: [id], onDelete: Cascade)
  cloudflareAccountId Int
}

model AlertRule {
  id          Int      @id @default(autoincrement())
  name        String
  metric      String   // cpu_load_1 | mem_percent | disk_percent | unhealthy_containers | container_down
  operator    String   // > | < | == | >= | <=
  threshold   Float
  durationSec Int      @default(60) // must breach for this long
  enabled     Boolean  @default(true)
  severity    String   @default("warning") // info | warning | error | critical
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AlertSetting {
  id            Int      @id @default(autoincrement())
  retentionDays Int      @default(30)
  updatedAt     DateTime @updatedAt
}
