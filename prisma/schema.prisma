generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                 Int      @id @default(autoincrement())
  username           String   @unique
  password           String   // bcrypt hash
  role               String   @default("admin")
  forcePasswordChange Boolean @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  auditLogs AuditLog[]
  aiThreads AiThread[]
  guideProgress UserGuideProgress[]
}

model AuditLog {
  id          Int      @id @default(autoincrement())
  userId      Int
  action      String   // login | logout | password_change | login_failed
  ip          String   @default("")
  userAgent   String   @default("")
  metadata    String   @default("") // JSON string for extra context
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([action, createdAt])
}

model VpsConfig {
  id        Int      @id @default(autoincrement())
  name      String   @default("primary")
  host      String
  port      Int      @default(22)
  username  String   @default("root")
  privateKey String? // AES-256-GCM encrypted at rest (see src/lib/crypto.ts)
  authType  String   @default("key") // key | password
  password  String? // AES-256-GCM encrypted at rest (see src/lib/crypto.ts)
  isLocal   Boolean  @default(false) // true = running on VPS, exec directly
  isActive  Boolean  @default(false) // exactly one active VPS; all pages target it
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  systemConfig SystemConfig?
  deploymentTargets DeploymentTarget[]
  enrolledDeployments EnrolledDeployment[]
}

model Project {
  id          Int      @id @default(autoincrement())
  slug        String   @unique
  name        String
  domain      String?
  path        String   // /opt/slug or /var/www/slug
  repoUrl     String?
  buildCommand String?
  outputDir   String?
  dockerfile  String?
  envVars     String?  // JSON object of default env vars
  caddyFile   String?
  dockerCompose String?
  category    String   @default("app") // app | static | docker
  status      String   @default("unknown")
  lastDeploy  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  projectGroupId Int?

  deployments Deployment[]
  envProfiles DeploymentEnvProfile[]
  projectGroup ProjectGroup? @relation(fields: [projectGroupId], references: [id], onDelete: SetNull)
  inventoryRecord EnrolledDeployment?

  @@index([projectGroupId])
}

// A Project is intentionally only an operator-created group of deployments.
// The legacy Project model above remains the deployed workload record until the
// deployment/revision table rename is completed in a backwards-compatible step.
model ProjectGroup {
  id          Int      @id @default(autoincrement())
  slug        String   @unique
  name        String
  description String   @default("")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  deployments Project[]
  enrolledDeployments EnrolledDeployment[]
}

// Stable operator-owned identity for a workload discovered on a host. This is
// deliberately separate from Deployment, which records individual releases.
model EnrolledDeployment {
  id              Int      @id @default(autoincrement())
  name            String
  slug            String   @unique
  kind            String
  managementMode  String   @default("track") // track | managed
  sourcePath      String?
  composePath     String?
  containerName   String?
  systemdUnit     String?
  status          String   @default("unknown")
  metadataJson    String   @default("{}")
  lastSeenAt      DateTime?
  projectGroupId  Int?
  vpsConfigId     Int?
  legacyProjectId Int?     @unique
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  projectGroup  ProjectGroup? @relation(fields: [projectGroupId], references: [id], onDelete: SetNull)
  vpsConfig     VpsConfig?    @relation(fields: [vpsConfigId], references: [id], onDelete: Cascade)
  legacyProject Project?      @relation(fields: [legacyProjectId], references: [id], onDelete: SetNull)

  @@unique([vpsConfigId, sourcePath])
  @@unique([vpsConfigId, containerName])
  @@index([projectGroupId, updatedAt])
  @@index([vpsConfigId, status])
}

model DeploymentTarget {
  id           Int      @id @default(autoincrement())
  name         String
  type         String   // docker-compose | static | nixpacks | custom
  vpsConfigId  Int?
  cloudProviderAccountId Int? // GCP/AWS/Azure account for cloud targets
  configJson   String   @default("") // target-specific configuration
  isActive     Boolean  @default(false)
  dnsRecordId  String?  // Cloudflare DNS record created by this target
  dnsRecordName String? // Name of the Cloudflare DNS record created by this target
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  vps VpsConfig? @relation(fields: [vpsConfigId], references: [id], onDelete: SetNull)
  cloudAccount CloudProviderAccount? @relation(fields: [cloudProviderAccountId], references: [id], onDelete: SetNull)
  deployments Deployment[]

  @@index([type, isActive])
}

model Job {
  id          Int      @id @default(autoincrement())
  type        String   // deploy | build | rollback | terraform_apply
  status      String   @default("pending") // pending | running | success | failed | cancelled
  payload     String   // JSON
  output      String   @default("")
  result      String?  // JSON
  error       String?
  startedAt   DateTime?
  finishedAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  deployments Deployment[]

  @@index([status, createdAt])
  @@index([type, status])
}

model Deployment {
  id                 Int      @id @default(autoincrement())
  projectId          Int
  targetId           Int
  jobId              Int?     // Background job tracking real-time logs
  status             String   @default("pending") // pending | building | deploying | success | failed | rolled_back
  branch             String   @default("main")
  commitSha          String?
  imageTag           String?
  publicUrl          String?
  previewUrl         String?
  previewProcessInfo String?  // PID/log path for ephemeral quick tunnels
  idempotencyKey     String?
  output             String?
  error              String?
  durationMs         Int?
  envProfileId       Int?
  envProviderType    String?
  envHash            String?
  envStatus          String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  target  DeploymentTarget @relation(fields: [targetId], references: [id], onDelete: Cascade)
  job     Job? @relation(fields: [jobId], references: [id], onDelete: SetNull)
  envProfiles DeploymentEnvProfile[]

  @@index([projectId, createdAt])
  @@index([targetId, createdAt])
  @@index([idempotencyKey])
}

model EnvProviderAccount {
  id          Int      @id @default(autoincrement())
  name        String
  provider    String   @default("local") // local | infisical | future providers
  configJson  String   @default("") // non-secret provider settings
  credentials String   @default("") // encrypted JSON credentials
  isActive    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  envProfiles DeploymentEnvProfile[]

  @@index([provider, isActive])
}

model DeploymentEnvProfile {
  id                Int      @id @default(autoincrement())
  projectId         Int
  deploymentId      Int?
  providerType      String   @default("local")
  providerAccountId Int?
  environment       String   @default("prod")
  secretPath        String   @default("/")
  projectRef        String   @default("") // Infisical workspace/project ID or provider-specific ref
  schemaJson        String   @default("[]")
  status            String   @default("unknown") // unknown | missing | valid | synced | stale | failed
  lastHash          String?
  lastSyncedAt      DateTime?
  lastError         String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  deployment Deployment? @relation(fields: [deploymentId], references: [id], onDelete: SetNull)
  providerAccount EnvProviderAccount? @relation(fields: [providerAccountId], references: [id], onDelete: SetNull)
  values DeploymentEnvValue[]

  @@index([projectId, providerType])
  @@index([deploymentId])
  @@index([providerAccountId])
}

model DeploymentEnvValue {
  id        Int      @id @default(autoincrement())
  profileId Int
  key       String
  value     String   @default("") // encrypted at rest
  required  Boolean  @default(false)
  source    String   @default("local") // local | imported | generated
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  profile DeploymentEnvProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([profileId, key])
  @@index([profileId])
}

model DeploymentLog {
  id        Int      @id @default(autoincrement())
  projectSlug String
  status    String   @default("running") // running | success | failed | rolled_back
  commitSha String?
  branch    String   @default("main")
  output    String?
  error     String?
  durationMs Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Alert {
  id        Int      @id @default(autoincrement())
  title     String
  message   String
  severity  String   @default("info") // info | warning | error | critical
  source    String   @default("system")
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model MetricSnapshot {
  id        Int      @id @default(autoincrement())
  cpuLoad1  Float
  cpuLoad5  Float
  cpuLoad15 Float
  memUsed   Float
  memTotal  Float
  memPercent Float
  diskUsed  Float
  diskTotal Float
  diskPercent Float
  containerCount Int
  runningContainers Int
  unhealthyContainers Int
  createdAt DateTime @default(now())
}

model SiteContainerMap {
  id            Int      @id @default(autoincrement())
  siteDomain    String
  containerName String
  createdAt     DateTime @default(now())

  @@unique([siteDomain, containerName])
}

model SystemConfig {
  id             Int    @id @default(autoincrement())
  vpsConfigId    Int?   @unique // links this filesystem layout to a specific VPS; null = global/legacy default
  projectRoot    String @default("/opt")
  templateDeploymentRoot String @default("/srv/groundcontrol/deployments")
  caddySitesDir  String @default("/etc/caddy/sites")
  caddyFile      String @default("/etc/caddy/Caddyfile")
  nginxSitesDir  String @default("/etc/nginx/sites-available")
  nginxLogPath   String @default("/var/log/nginx/error.log")
  staticRoot     String @default("/var/www")
  sshDefaultCwd  String @default("/root")
  certDomain     String @default("")
  composeCommand String? // override docker compose command: "docker compose", "docker-compose", "podman-compose"
  updatedAt      DateTime @updatedAt

  vps VpsConfig? @relation(fields: [vpsConfigId], references: [id], onDelete: Cascade)
}

model CloudProviderAccount {
  id          Int      @id @default(autoincrement())
  name        String
  provider    String   // gcp | aws | azure
  credentials String   // encrypted JSON
  isActive    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  deploymentTargets DeploymentTarget[]

  @@index([provider, isActive])
}

model TerraformStack {
  id           Int      @id @default(autoincrement())
  name         String
  provider     String   // hetzner | aws | gcp | azure
  workspace    String   @default("default")
  hcl          String   // generated Terraform configuration
  varsJson     String   @default("") // encrypted terraform.tfvars
  stateBackend String   @default("local") // local | s3 | gcs
  statePath    String?  // where state is stored
  lastPlan     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([provider, workspace])
}

model CloudflareAccount {
  id          Int      @id @default(autoincrement())
  name        String   @default("Cloudflare")
  apiToken    String   // encrypted at rest
  accountId   String?
  email       String?
  isActive    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tunnels CloudflareTunnel[]
}

model CloudflareTunnel {
  id          Int      @id @default(autoincrement())
  tunnelId    String   @unique // Cloudflare tunnel ID (UUID)
  name        String
  tunnelSecret String? // base64 secret for cloudflared
  connectorId String?  // optional running container id
  status      String   @default("inactive") // active | inactive | error
  domains     String   @default("") // comma-separated list
  configJson  String   @default("") // ingress JSON snapshot
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  account CloudflareAccount @relation(fields: [cloudflareAccountId], references: [id], onDelete: Cascade)
  cloudflareAccountId Int
}

model AlertRule {
  id          Int      @id @default(autoincrement())
  name        String
  metric      String   // cpu_load_1 | mem_percent | disk_percent | unhealthy_containers | container_down
  operator    String   // > | < | == | >= | <=
  threshold   Float
  durationSec Int      @default(60) // must breach for this long
  enabled     Boolean  @default(true)
  severity    String   @default("warning") // info | warning | error | critical
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AlertSetting {
  id            Int      @id @default(autoincrement())
  retentionDays Int      @default(30)
  updatedAt     DateTime @updatedAt
}

model HealthCheckConfig {
  id          Int       @id @default(autoincrement())
  intervalSec Int       @default(60)
  enabled     Boolean   @default(true)
  severity    String    @default("error") // info | warning | error | critical
  lastRunAt   DateTime?
  lastStatus  String?   // ok | degraded | down
  updatedAt   DateTime  @updatedAt
}

model HealthCheckResult {
  id            Int      @id @default(autoincrement())
  containerName String
  status        String   // healthy | unhealthy | down
  detail        String   @default("")
  checkedAt     DateTime @default(now())

  @@index([containerName, checkedAt])
  @@index([checkedAt])
}

// -----------------------------------------------------------------------------
// AI operator memory
// -----------------------------------------------------------------------------

model AiThread {
  id        Int      @id @default(autoincrement())
  userId    Int
  title     String   @default("New chat")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages AiMessage[]

  @@index([userId, updatedAt])
}

model AiMessage {
  id        Int      @id @default(autoincrement())
  threadId  Int
  role      String   // user | assistant | system | tool
  content   String   @default("")
  sortOrder Int      @default(0)
  metadata  String   @default("{}") // JSON: confirmation state, provider, model, etc.
  createdAt DateTime @default(now())

  thread    AiThread     @relation(fields: [threadId], references: [id], onDelete: Cascade)
  toolCalls AiToolCall[]

  @@index([threadId, sortOrder])
}

model AiToolCall {
  id          Int       @id @default(autoincrement())
  messageId   Int
  name        String
  args        String    @default("{}") // JSON
  output      String?
  status      String    @default("pending") // pending | running | done | error | confirmed
  readOnly    Boolean   @default(true)
  confirmedAt DateTime?
  createdAt   DateTime  @default(now())

  message AiMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId])
}

model AiUsage {
  id           Int      @id @default(autoincrement())
  threadId     Int?
  messageId    Int?
  provider     String
  model        String
  inputTokens  Int?
  outputTokens Int?
  totalTokens  Int?
  costUsd      Float?
  createdAt    DateTime @default(now())

  @@index([threadId, createdAt])
}

// -----------------------------------------------------------------------------
// Interactive learning guides
// -----------------------------------------------------------------------------

model Guide {
  id          Int      @id @default(autoincrement())
  slug        String   @unique
  title       String
  description String   @default("")
  category    String   // integration | incident | concept | checklist
  sourceRef   String   @default("") // e.g. docs/INTEGRATION-GUIDE.md
  stepsJson   String   // JSON array of GuideStep objects
  isPublished Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  progress UserGuideProgress[]

  @@index([category, isPublished])
  @@index([slug, isPublished])
}

model UserGuideProgress {
  id               Int      @id @default(autoincrement())
  userId           Int
  guideId          Int
  currentStepId    String   @default("")
  completedStepIds String   @default("[]") // JSON array of step ids
  status           String   @default("not_started") // not_started | in_progress | completed
  startedAt        DateTime?
  completedAt      DateTime?
  updatedAt        DateTime @updatedAt

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  guide Guide @relation(fields: [guideId], references: [id], onDelete: Cascade)

  @@unique([userId, guideId])
  @@index([userId, status])
}
